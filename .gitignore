# Root .gitignore for GenAI Engine project

# Node.js
**/node_modules/
**/dist/
**/build/
**/*.local
frontend/build_check.log
frontend/build_output.txt

# Python
**/venv/
**/*.pyc
**/__pycache__/

# Environment variables
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Logs
**/*.log

# Editor directories and files
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
